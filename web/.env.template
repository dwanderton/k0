# cp .env.template .env.local — never commit .env.local
# Values live in Vercel project env (prod/preview) and GitHub Actions
# secrets; this file documents what local dev needs.

# Gladia live transcription — session mint (transcribe-session route 503s
# without it). Dashboard: gladia.io → API keys.
GLADIA_API_KEY=

# Vercel MCP fallback search — scoped token, used only when local
# retrieval FAILS. Rotate by replacing here + in Vercel env.
VERCEL_MCP_TOKEN=

# Session card parking — auto-injected on Vercel when the k0-sessions
# Blob store is attached; for local dev copy from `vercel env pull`.
BLOB_READ_WRITE_TOKEN=

# Scorecard probe bypass (BotID + WAF rate limit). Also lives as a
# GitHub Actions secret — rotate BOTH places to revoke.
SCORECARD_PROBE_SECRET=

# AI Gateway auth for local runs. Either works:
#  - AI_GATEWAY_API_KEY (static; what CI uses), or
#  - VERCEL_OIDC_TOKEN via `vercel env pull` (~24h expiry)
AI_GATEWAY_API_KEY=
VERCEL_OIDC_TOKEN=
